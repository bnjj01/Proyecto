        $sql = "UPDATE {$this->table} 
                SET nombre = :nombre, 
                    codigo = :codigo, 
                    descripcion = :descripcion, 
                    categoriaId = :categoriaId, 
                    precio = :precio, 
                    stock = :stock 
                WHERE id = :id";
        $stmt = $this->conn->prepare($sql);
        $stmt->execute($data);
    }


